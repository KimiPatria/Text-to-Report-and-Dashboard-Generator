GROQ_API_KEY=your_key_here
DATABASE_URL=postgresql://username:password@host:5432/dbname
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_120B=openai/gpt-oss-120b
GROQ_MODEL_20B=openai/gpt-oss-20b
DEFAULT_PROVIDER=groq
MAX_RESULT_ROWS=100
STATEMENT_TIMEOUT_MS=15000
DB_SCHEMA=public

# --- dynamic routing (iteration 2) ---
ROUTING_MODEL=llama-3.1-8b-instant
CATALOG_TTL_SECONDS=1800
MAX_ROUTED_TABLES=12
GLOSSARY_PATH=./glossary.yaml
